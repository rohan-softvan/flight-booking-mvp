# --- Postgres ---
POSTGRES_USER=flightbooking
POSTGRES_PASSWORD=flightbooking
POSTGRES_DB=flightbooking
# host-side port only (containers always talk to each other over "db:5432" internally) -
# 5433 avoids clashing with a default local/other-project Postgres on 5432
POSTGRES_HOST_PORT=5433
DATABASE_URL=postgres://flightbooking:flightbooking@db:5432/flightbooking

# --- Backend ---
BACKEND_PORT=4000
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# --- Frontend (build-time, Vite requires the VITE_ prefix) ---
VITE_API_BASE_URL=http://localhost:4000
